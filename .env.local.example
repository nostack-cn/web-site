# 站点基础配置
NEXT_PUBLIC_SITE_URL=https://nostack.cloud

# yungouos 聚合支付配置
YUNGOUOS_MCH_ID=your_mch_id
YUNGOUOS_API_KEY=your_api_key
YUNGOUOS_NOTIFY_URL=https://nostack.cloud/api/payment/callback

# 后端 API
NEXT_PUBLIC_API_BASE_URL=https://api.nostack.cloud

# svr-admin 博客内部 API（构建时获取博客数据）
SVR_ADMIN_URL=http://localhost:8080
BLOG_INTERNAL_KEY=your-blog-internal-key
